---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Header } from '../../components/layout/Header';
import { Footer } from '../../components/layout/Footer';
import { ArrowLeft, ArrowUpRight } from 'lucide-react';
import { db } from '../../db/index.server';
import { competitions } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { Button } from '../../components/ui/button';
import { HowItWorks } from '../../components/sections/HowItWorks';
import { ScoringSection } from '../../components/sections/ScoringSection';
import { RegistrationSection } from '../../components/sections/RegistrationSection';
import { formatDeadline, formatINR } from '../../data/competitions';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/competitions');
}

let competition = null;

try {
  const results = await db
    .select()
    .from(competitions)
    .where(eq(competitions.slug, slug))
    .limit(1);

  if (results.length > 0) {
    competition = results[0];
  }
} catch (error) {
  console.error(`Failed to fetch competition ${slug}:`, error);
}

if (!competition) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={competition.title} description={competition.subtitle}>
  <Header season={competition.season} client:load />

  <main>
    <section class="pt-32 pb-16 px-6 lg:px-8 border-b border-border/60">
      <div class="max-w-7xl mx-auto">
        <a
          href="/competitions"
          class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground"
        >
          <ArrowLeft className="size-4" /> All competitions
        </a>
        <div class="mt-8 grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-8">
            <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-muted-foreground">
              {competition.season}
            </p>
            <h1 class="font-display text-balance mt-3 text-6xl md:text-7xl leading-[0.95]">
              {competition.title}. <em class="italic text-muted-foreground">{competition.subtitle}</em>
            </h1>
            <p class="mt-6 max-w-2xl text-lg text-muted-foreground leading-relaxed">
              {competition.description}
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <Button asChild size="lg" className="rounded-full px-6 h-12">
                <a href="/#register">
                  Register for {formatINR(competition.entryFeeINR)}
                  <ArrowUpRight className="ml-1 size-4" />
                </a>
              </Button>
            </div>
          </div>
          <aside class="lg:col-span-4 rounded-3xl border border-border bg-card p-8">
            <dl class="space-y-6">
              <div class="flex items-baseline justify-between gap-6 border-b border-border/70 pb-4 last:border-0 last:pb-0">
                <dt class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground">Prize</dt>
                <dd class="font-display text-3xl text-foreground tracking-tight">{formatINR(competition.prizeINR)}</dd>
              </div>
              <div class="flex items-baseline justify-between gap-6 border-b border-border/70 pb-4 last:border-0 last:pb-0">
                <dt class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground">Entry</dt>
                <dd class="text-base text-foreground tracking-tight">{formatINR(competition.entryFeeINR)}</dd>
              </div>
              <div class="flex items-baseline justify-between gap-6 border-b border-border/70 pb-4 last:border-0 last:pb-0">
                <dt class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground">Deadline</dt>
                <dd class="text-base text-foreground tracking-tight">{formatDeadline(competition.deadline)}</dd>
              </div>
              <div class="flex items-baseline justify-between gap-6 border-b border-border/70 pb-4 last:border-0 last:pb-0">
                <dt class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground">Hashtag</dt>
                <dd class="font-mono text-sm text-foreground tracking-tight">{competition.hashtag}</dd>
              </div>
              <div class="flex items-baseline justify-between gap-6 border-b border-border/70 pb-4 last:border-0 last:pb-0">
                <dt class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground">Platforms</dt>
                <dd class="text-base text-foreground tracking-tight">{(competition.platforms as string[]).join(' \u00b7 ')}</dd>
              </div>
            </dl>
          </aside>
        </div>
      </div>
    </section>

    <HowItWorks competition={competition} client:visible />
    <ScoringSection competition={competition} client:visible />
    <RegistrationSection competition={competition} client:visible />
  </main>

  <Footer season={competition.season} />
</BaseLayout>
